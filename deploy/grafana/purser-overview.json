{
  "title": "Purser — Model Scan Security",
  "uid": "purser-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "tags": ["purser", "security", "ml"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Scans/min by verdict",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 10, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "cpm" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "expr": "sum by (verdict) (rate(purser_scans_total[$__rate_interval])) * 60", "legendFormat": "{{verdict}}" }
      ]
    },
    {
      "id": 2, "type": "stat", "title": "Scans in progress",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 4, "x": 10, "y": 0 },
      "targets": [ { "expr": "sum(purser_scans_in_progress)" } ]
    },
    {
      "id": 3, "type": "stat", "title": "p95 scan duration",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 5, "x": 14, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(purser_scan_duration_seconds_bucket[$__rate_interval])))" }
      ]
    },
    {
      "id": 4, "type": "stat", "title": "Blocked + Failed / total (1h)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 5, "x": 19, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        { "expr": "sum(increase(purser_scans_total{verdict=~\"FAIL|BLOCKED\"}[1h])) / clamp_min(sum(increase(purser_scans_total[1h])), 1)" }
      ]
    },
    {
      "id": 5, "type": "timeseries", "title": "Findings by threat category",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "topk(10, sum by (category) (rate(purser_findings_by_category_total[$__rate_interval])))", "legendFormat": "{{category}}" }
      ]
    },
    {
      "id": 6, "type": "timeseries", "title": "Policy blocks by reason",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "sum by (reason) (rate(purser_policy_blocks_total[$__rate_interval]))", "legendFormat": "{{reason}}" }
      ]
    },
    {
      "id": 7, "type": "piechart", "title": "Provenance / signature status",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "targets": [
        { "expr": "sum by (status) (increase(purser_provenance_total[1h]))", "legendFormat": "{{status}}" }
      ]
    },
    {
      "id": 8, "type": "timeseries", "title": "Scans by origin (top 10)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
      "targets": [
        { "expr": "topk(10, sum by (origin) (rate(purser_scans_by_origin_total[$__rate_interval])))", "legendFormat": "{{origin}}" }
      ]
    },
    {
      "id": 9, "type": "timeseries", "title": "Files scanned by format",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "targets": [
        { "expr": "topk(10, sum by (format) (rate(purser_scan_files_total[$__rate_interval])))", "legendFormat": "{{format}}" }
      ]
    },
    {
      "id": 10, "type": "timeseries", "title": "API requests rejected by reason",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 22 },
      "targets": [
        { "expr": "sum by (reason) (rate(purser_requests_rejected_total[$__rate_interval]))", "legendFormat": "{{reason}}" }
      ]
    },
    {
      "id": 11, "type": "timeseries", "title": "Throughput & errors",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 22 },
      "targets": [
        { "expr": "rate(purser_bytes_scanned_total[$__rate_interval])", "legendFormat": "bytes/s" },
        { "expr": "rate(purser_scan_errors_total[$__rate_interval])", "legendFormat": "errors/s" }
      ]
    }
  ]
}
